# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-secret-here

# Set to your Vercel URL in production (e.g. https://stockhealthmanagement.vercel.app)
# Leave blank for local dev (defaults to http://localhost:3000)
NEXTAUTH_URL=

# ─── Google OAuth (free) ──────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client
# 3. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#    (Add your Vercel URL too: https://your-app.vercel.app/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth (free) ─────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Homepage URL: http://localhost:3000
# 3. Callback URL: http://localhost:3000/api/auth/callback/github
#    (Update to Vercel URL for production)
GITHUB_ID=
GITHUB_SECRET=

# ─── Supabase (free tier) ────────────────────────────────────────────────────
# 1. Go to https://supabase.com → New project (free)
# 2. Settings → API → copy URL and service_role key
# 3. Run supabase/schema.sql in the SQL Editor
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
